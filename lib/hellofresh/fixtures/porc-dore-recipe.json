  "steps": [
    {
      "id": "6a1ea349eb2a01bc740dd4fd",
      "index": 1,
      "instructions": "<ul>\n<li>Veillez à bien respecter les quantités indiquées à gauche pour préparer votre recette !</li>\n<li>Préchauffez le four à 220°C (200°C chaleur tournante). </li>\n<li>Lavez bien ou épluchez les pommes de terre, puis coupez-les en potatoes de 1 cm de large. Placez-les sur une plaque recouverte de papier sulfurisé.</li>\n<li>Arrosez-les d&#39;un filet d&#39;huile d&#39;olive, salez et saupoudrez-les de 1 pincée de romarin séché (selon votre goût). Mélangez bien.</li>\n<li>Enfournez-les 25-35 min dans la partie haute du four, ou jusqu’à ce qu’elles soient dorées et croustillantes. Remuez à mi-cuisson.</li>\n</ul>",
      "instructionsHTML": "<ul>\n<li>Veillez à bien respecter les quantités indiquées à gauche pour préparer votre recette !</li>\n<li>Préchauffez le four à 220°C (200°C chaleur tournante). </li>\n<li>Lavez bien ou épluchez les pommes de terre, puis coupez-les en potatoes de 1 cm de large. Placez-les sur une plaque recouverte de papier sulfurisé.</li>\n<li>Arrosez-les d&#39;un filet d&#39;huile d&#39;olive, salez et saupoudrez-les de 1 pincée de romarin séché (selon votre goût). Mélangez bien.</li>\n<li>Enfournez-les 25-35 min dans la partie haute du four, ou jusqu’à ce qu’elles soient dorées et croustillantes. Remuez à mi-cuisson.</li>\n</ul>",
      "instructionsMarkdown": "<ul>\n<li>Veillez à bien respecter les quantités indiquées à gauche pour préparer votre recette !</li>\n<li>Préchauffez le four à 220°C (200°C chaleur tournante). </li>\n<li>Lavez bien ou épluchez les pommes de terre, puis coupez-les en potatoes de 1 cm de large. Placez-les sur une plaque recouverte de papier sulfurisé.</li>\n<li>Arrosez-les d&#39;un filet d&#39;huile d&#39;olive, salez et saupoudrez-les de 1 pincée de romarin séché (selon votre goût). Mélangez bien.</li>\n<li>Enfournez-les 25-35 min dans la partie haute du four, ou jusqu’à ce qu’elles soient dorées et croustillantes. Remuez à mi-cuisson.</li>\n</ul>",
      "images": [
